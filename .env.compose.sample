# Copy this file to .env when running the local Docker Compose stack.
# Uncomment only the values you need to override. Keep real secrets out of git.

# Shared Postgres settings used by Postgres, Hasura, and Envio.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=testing
# POSTGRES_DB=envio-dev

# Hasura is internal-only in compose. The publisher uses this secret.
# HASURA_GRAPHQL_ADMIN_SECRET=local-dev-secret
# HASURA_PORT=8080

# Local S3-compatible artifact storage.
# MINIO_ROOT_USER=metricsadmin
# MINIO_ROOT_PASSWORD=metrics-local-password
# ARTIFACT_BUCKET=metrics
# ARTIFACT_ENDPOINT=http://minio:9000
# ARTIFACT_REGION=us-east-1
# ARTIFACT_ACCESS_KEY_ID=metricsadmin
# ARTIFACT_SECRET_ACCESS_KEY=metrics-local-password

# Public host port for metrics-api.
# METRICS_API_PORT=3000
# METRICS_API_MAX_RANGE_DAYS=366

# Envio indexer.
# ENVIO_API_TOKEN=CHANGEME
# ENVIO_PG_HOST=postgres
# ENVIO_PG_PORT=5432
# ENVIO_PG_USER=postgres
# ENVIO_PG_PASSWORD=testing
# ENVIO_PG_DATABASE=envio-dev
# ENVIO_PG_SCHEMA=public
# ENVIO_PG_SSL_MODE=false
# ENVIO_PG_MAX_CONNECTIONS=2
# INDEXER_HASURA_GRAPHQL_ENDPOINT=http://hasura:8080/v1/metadata
# INDEXER_PORT=9898
# ENVIO_MAX_PARTITION_CONCURRENCY=10

# Per-chain archive RPC URLs. Override these with reliable archive providers
# before running historical indexer backfills.
# ENVIO_ETHEREUM_RPC_URL=https://eth.llamarpc.com
# ENVIO_ARBITRUM_RPC_URL=https://arbitrum.rpc.subquery.network/public
# ENVIO_BASE_RPC_URL=https://base.llamarpc.com
# ENVIO_BERACHAIN_RPC_URL=https://rpc.berachain.com
# ENVIO_POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
# ENVIO_FANTOM_RPC_URL=https://rpcapi.fantom.network

# Snapshot effect RPC client tuning. These are used by this repository's viem
# snapshot reads, not by Envio's event ingestion engine.
# ENVIO_RPC_HTTP_BATCH_SIZE=10
# ENVIO_RPC_MULTICALL_BATCH_SIZE=128
# ENVIO_RPC_TIMEOUT_MS=30000

# Publisher profile.
# HASURA_GRAPHQL_ENDPOINT=http://hasura:8080/v1/graphql
# PUBLISHER_PUBLIC_START_DATE=2022-05-01
# PUBLISHER_LOOKBACK_DAYS=3
# PUBLISHER_LOCK_TTL_MS=43200000
# Usually provided by `pnpm run compose:publish` from `git rev-parse HEAD`.
# Set manually only when running docker compose directly.
# INDEXER_DEPLOYMENT_ID=<git-commit-hash>
# PUBLISHER_START_DATE=
# PUBLISHER_END_DATE=
