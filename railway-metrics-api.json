{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile-metrics-api",
    "watchPatterns": [
      "Dockerfile-metrics-api",
      "railway-metrics-api.json",
      "apps/metrics-api/**",
      "packages/metrics-artifacts/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/ready",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ALWAYS"
  }
}
