{
  "name": "olympus-subgraph",
  "version": "0.1.0",
  "description": "Subgraphs for OlympusDAO. NOTE: This does not build a package.",
  "author": {
    "name": "Jem",
    "email": "0x0xjem@gmail.com",
    "url": "https://github.com/0xJem"
  },
  "private": true,
  "type": "module",
  "repository": "https://github.com/OlympusDAO/olympus-protocol-metrics-subgraph",
  "scripts": {
    "build": "tsc --noEmit",
    "check": "biome check .",
    "codegen": "pnpm --dir apps/indexer codegen",
    "compose:config": "docker compose config",
    "compose:publish": "docker compose --profile publish run --rm metrics-publisher",
    "compose:up": "docker compose up --build postgres hasura minio minio-init indexer metrics-api",
    "envio": "pnpm --dir apps/indexer envio",
    "envio:dev": "pnpm --dir apps/indexer envio:dev",
    "envio:start": "pnpm --dir apps/indexer envio:start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm test:root && pnpm test:indexer",
    "test:root": "vitest run --dir tests",
    "test:indexer": "pnpm --dir apps/indexer test",
    "validate": "pnpm run check && pnpm run build && pnpm test",
    "lint": "biome lint --write .",
    "lint:check": "biome lint ."
  },
  "dependencies": {
    "bignumber.js": "9.1.2",
    "envio": "3.0.1",
    "graphql": "^16.8.1",
    "viem": "2.48.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "24.12.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": "^22 || ^24",
    "pnpm": ">=10.32.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "packageManager": "pnpm@10.33.0"
}
