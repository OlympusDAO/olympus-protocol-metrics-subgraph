{
  "name": "olympus-subgraph",
  "version": "0.1.0",
  "description": "Subgraphs for OlympusDAO. NOTE: This does not build a package.",
  "author": {
    "name": "Jem",
    "email": "0x0xjem@gmail.com",
    "url": "https://github.com/0xJem"
  },
  "private": true,
  "repository": "https://github.com/OlympusDAO/olympus-protocol-metrics-subgraph",
  "scripts": {
    "create-local": "graph create --node http://localhost:8020/ olympus",
    "remove-local": "graph remove --node http://localhost:8020/ olympus",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 olympus",
    "ls-deadcode": "yarn ts-prune -p tsconfig.ts-prune.json | grep -v 'used in module'",
    "subgraph": "ts-node bin/subgraph/src/index.ts",
    "lint": "eslint --fix .",
    "lint:check": "eslint --max-warnings 0 .",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "dependencies": {
    "@apollo/client": "^3.8.4",
    "@graphprotocol/graph-cli": "^0.96.0",
    "@graphprotocol/graph-ts": "^0.35.0",
    "assemblyscript-json": "^1.1.0",
    "commander": "^9.4.0",
    "cross-fetch": "^4.0.0",
    "dotenv": "^16.0.2",
    "graphql": "^16.8.1",
    "node-fetch": "^2.6.7",
    "ts-node": "^10.9.1"
  },
  "devDependencies": {
    "@types/json-diff": "^0.7.0",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "assemblyscript": "0.19.10",
    "eslint": "^9.22.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "json-diff": "^0.9.0",
    "matchstick-as": "^0.5.0",
    "mustache": "^4.2.0",
    "prettier": "^2.6.2",
    "ts-prune": "^0.10.3",
    "typescript": "^4.9.3"
  },
  "resolutions": {
    "ejs": "^3.1.7",
    "node-forge": "^1.3.0",
    "node-fetch": "^2.6.7",
    "ramda": "^0.27.2",
    "yargs-parser": "^18.1.1"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "@pnpm/npm-conf": "^3.0.2",
      "ajv": "6.14.0",
      "axios": "^1.15.1",
      "brace-expansion": "^2.0.3",
      "cross-spawn": "^7.0.5",
      "diff@>=4.0.0 <4.0.4": "^4.0.4",
      "ejs": "^3.1.10",
      "es5-ext@>=0.10.0 <0.10.63": "^0.10.63",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "glob": "^11.1.0",
      "immutable": "^5.1.5",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.0",
      "lodash.trim": "4.18.0",
      "lodash.trimend": "4.18.0",
      "minimatch": "^10.2.3",
      "picomatch": "^2.3.2",
      "semver": "^7.5.2",
      "tmp@<=0.2.3": "^0.2.4",
      "undici": "^7.24.0",
      "yaml": "^2.8.3"
    }
