{
  "name": "@olympusdao/treasury-subgraph",
  "version": "0.1.0",
  "description": "Subgraphs for the Olympus treasury",
  "author": {
    "name": "Jem",
    "email": "0x0xjem@gmail.com",
    "url": "https://github.com/0xJem"
  },
  "private": true,
  "type": "module",
  "repository": "https://github.com/OlympusDAO/olympus-protocol-metrics-subgraph",
  "scripts": {
    "build": "tsc --noEmit && pnpm --dir apps/client build",
    "check": "biome check .",
    "codegen": "pnpm --dir apps/indexer codegen",
    "compose:api": "docker compose up --build minio minio-init metrics-api",
    "compose:api:rebuild": "docker compose up --build --no-deps metrics-api",
    "compose:bucket:clear": "docker compose run --rm --no-deps --entrypoint /bin/sh minio-init -c 'mc alias set local http://minio:9000 \"$MINIO_ROOT_USER\" \"$MINIO_ROOT_PASSWORD\" && mc rm --recursive --force \"local/${ARTIFACT_BUCKET:-metrics}\" && mc mb -p \"local/${ARTIFACT_BUCKET:-metrics}\"'",
    "compose:config": "docker compose config",
    "compose:core": "docker compose up postgres hasura indexer",
    "compose:publish": "INDEXER_DEPLOYMENT_ID=$(git rev-parse HEAD) docker compose --profile publish run --build --rm --no-deps metrics-publisher",
    "compose:up": "docker compose up --build postgres hasura minio minio-init indexer metrics-api",
    "docker:build:hasura": "docker build -f Dockerfile-hasura -t olympus-protocol-metrics/hasura:local .",
    "docker:build:indexer": "docker build -f Dockerfile-indexer -t olympus-protocol-metrics/indexer:local .",
    "docker:build:metrics-api": "docker build -f Dockerfile-metrics-api -t olympus-protocol-metrics/metrics-api:local .",
    "docker:build:metrics-publisher": "docker build -f Dockerfile-metrics-publisher -t olympus-protocol-metrics/metrics-publisher:local .",
    "docker:tag:scan:hasura": "docker tag olympus-protocol-metrics/hasura:local olympus-protocol-metrics/hasura:scan",
    "docker:tag:scan:indexer": "docker tag olympus-protocol-metrics/indexer:local olympus-protocol-metrics/indexer:scan",
    "docker:tag:scan:metrics-api": "docker tag olympus-protocol-metrics/metrics-api:local olympus-protocol-metrics/metrics-api:scan",
    "docker:tag:scan:metrics-publisher": "docker tag olympus-protocol-metrics/metrics-publisher:local olympus-protocol-metrics/metrics-publisher:scan",
    "envio": "pnpm --dir apps/indexer envio",
    "envio:dev": "pnpm --dir apps/indexer envio:dev",
    "envio:start": "pnpm --dir apps/indexer envio:start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm test:root && pnpm test:artifacts && pnpm test:client && pnpm test:metrics-api && pnpm test:metrics-publisher && pnpm test:indexer",
    "test:artifacts": "vitest run packages/metrics-artifacts/tests",
    "test:client": "pnpm --dir apps/client test",
    "test:metrics-api": "pnpm --dir apps/metrics-api test",
    "test:metrics-publisher": "pnpm --dir apps/metrics-publisher test",
    "test:root": "vitest run --dir tests",
    "test:indexer": "pnpm --dir apps/indexer test",
    "validate": "pnpm run check && pnpm run build && pnpm test",
    "lint": "biome lint --write .",
    "lint:check": "biome lint ."
  },
  "dependencies": {
    "bignumber.js": "9.1.2",
    "envio": "3.2.1",
    "tsx": "4.22.4",
    "viem": "2.53.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "24.12.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^24",
    "pnpm": ">=11.13.0 <12",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "packageManager": "pnpm@11.13.0"
}
