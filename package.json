{
  "name": "olympus-subgraph",
  "version": "0.1.0",
  "description": "Subgraphs for OlympusDAO. NOTE: This does not build a package.",
  "author": {
    "name": "Jem",
    "email": "0x0xjem@gmail.com",
    "url": "https://github.com/0xJem"
  },
  "private": true,
  "type": "module",
  "repository": "https://github.com/OlympusDAO/olympus-protocol-metrics-subgraph",
  "scripts": {
    "build": "tsc --noEmit",
    "check": "biome check .",
    "codegen": "envio codegen",
    "create-local": "graph create --node http://localhost:8020/ olympus",
    "remove-local": "graph remove --node http://localhost:8020/ olympus",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 olympus",
    "envio": "envio",
    "envio:dev": "ENVIO_TUI=${ENVIO_TUI:-false} envio dev",
    "envio:start": "envio start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "ls-deadcode": "yarn ts-prune -p tsconfig.ts-prune.json | grep -v 'used in module'",
    "subgraph": "tsx bin/subgraph/src/index.ts",
    "test": "vitest run --dir tests",
    "validate": "pnpm run format:check && pnpm run lint:check && pnpm run build && pnpm test",
    "lint": "biome lint --write .",
    "lint:check": "biome lint ."
  },
  "dependencies": {
    "@apollo/client": "^3.8.4",
    "@graphprotocol/graph-cli": "^0.96.0",
    "@graphprotocol/graph-ts": "^0.35.0",
    "assemblyscript-json": "^1.1.0",
    "bignumber.js": "9.1.2",
    "commander": "^9.4.0",
    "cross-fetch": "^4.0.0",
    "dotenv": "^16.0.2",
    "envio": "3.0.0-rc.0",
    "graphql": "^16.8.1",
    "node-fetch": "^2.6.7",
    "viem": "2.48.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/json-diff": "^0.7.0",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "assemblyscript": "0.19.10",
    "eslint": "^9.22.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "json-diff": "^0.9.0",
    "matchstick-as": "^0.5.0",
    "mustache": "^4.2.0",
    "prettier": "^2.6.2",
    "ts-prune": "^0.10.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "ajv": "6.14.0",
      "ajv@<6.14.0": "6.14.0",
      "axios": ">=1.15.1",
      "axios@<1.15.1": ">=1.15.1",
      "apisauce>axios": ">=1.15.1",
      "axios@<0.30.0": ">=0.30.0",
      "axios@<=0.30.2": ">=0.30.3",
      "axios@>=0.8.1 <0.28.0": ">=0.28.0",
      "brace-expansion": ">=2.0.3",
