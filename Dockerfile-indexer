FROM node:24-slim@sha256:242549cd46785b480c832479a730f4f2a20865d61ea2e404fdb2a5c3d3b73ecf

ENV CI=true
ENV PNPM_HOME=/pnpm
ENV COREPACK_HOME=/corepack
ENV PATH=/pnpm:$PATH

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /corepack /pnpm \
  && corepack enable \
  && corepack prepare pnpm@10.33.0 --activate \
  && pnpm --version \
  && chown -R node:node /corepack /pnpm

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
# pnpm validates every workspace importer under a frozen lockfile, so copy all
# package manifests before the full source copy. These are install/cache inputs,
# not runtime dependencies of this service.
COPY apps/indexer/package.json apps/indexer/package.json
COPY apps/metrics-api/package.json apps/metrics-api/package.json
COPY apps/metrics-publisher/package.json apps/metrics-publisher/package.json
COPY apps/client/package.json apps/client/package.json
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm --dir apps/indexer codegen
RUN pnpm run build
RUN chown -R node:node apps/indexer/.envio

USER node

CMD ["pnpm", "--dir", "apps/indexer", "envio:start"]
