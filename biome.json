{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      ".github/**",
      "apps/**",
      "packages/**",
      "tests/**",
      "*.json",
      "*.jsonc",
      "*.yaml",
      "*.yml",
      "!**/.envio",
      "!**/.pnpm-store",
      "!**/build",
      "!**/coverage",
      "!**/dist",
      "!**/generated",
      "!**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
