{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile-indexer",
    "watchPatterns": [
      "Dockerfile-indexer",
      "railway-indexer.json",
      "apps/indexer/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS"
  }
}
